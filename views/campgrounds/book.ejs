<% layout('layouts/boilerplate') %>

<div class="row">
    <div class="col-6 offset-3">
        <h1 class="text-center">Complete Your Booking</h1>
        
        <div class="card mb-3 mt-4 shadow-sm">
            <div class="card-body">
                <h3 class="card-title"><%= campground.title %></h3>
                <p class="card-text text-muted"><%= campground.location %></p>
                <hr>
                <div class="d-flex justify-content-between fs-4">
                    <span>Total Amount:</span>
                    <strong>$<%= campground.price %></strong>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <h4 class="mb-4">Payment Details</h4>
                <!-- This is a mock payment form -->
                <form action="/campgrounds/<%= campground._id %>/book" method="POST" class="needs-validation" novalidate>
                    
                    <div class="mb-3">
                        <label for="nameOnCard" class="form-label">Name on Card</label>
                        <input type="text" class="form-control" id="nameOnCard" required placeholder="John Doe">
                        <div class="invalid-feedback">
                            Please provide the name on the card.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="cardNumber" class="form-label">Card Number</label>
                        <input type="text" class="form-control" id="cardNumber" required placeholder="xxxx xxxx xxxx xxxx" pattern="\d{4}\s?\d{4}\s?\d{4}\s?\d{4}">
                        <div class="invalid-feedback">
                            Please provide a valid 16-digit card number.
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="expiry" class="form-label">Expiration Date</label>
                            <input type="text" class="form-control" id="expiry" required placeholder="MM/YY" pattern="(0[1-9]|1[0-2])\/?([0-9]{2})">
                            <div class="invalid-feedback">
                                Please provide a valid expiration date.
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label for="cvv" class="form-label">CVV</label>
                            <input type="text" class="form-control" id="cvv" required placeholder="123" pattern="\d{3,4}">
                            <div class="invalid-feedback">
                                Please provide a valid CVV.
                            </div>
                        </div>
                    </div>
                    
                    <div class="alert alert-info" role="alert">
                        <strong>Note:</strong> This is a mock payment page. No real transaction will occur.
                    </div>

                    <button class="btn btn-success w-100" type="submit">Pay $<%= campground.price %> & Book</button>
                    <a href="/campgrounds/<%= campground._id %>" class="btn btn-secondary w-100 mt-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
