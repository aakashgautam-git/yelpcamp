<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YelpCamp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        body {
            height: 100vh;
            background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)),
            url("https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?auto=format&fit=crop&w=1920&q=80");
            background-size: cover;
            background-position: center;
            text-shadow: 0 0.05rem 0.1rem rgba(0, 0, 0, 0.5);
            box-shadow: inset 0 0 5rem rgba(0, 0, 0, 0.5);
            color: white;
            margin: 0;
            padding: 0;
            overflow: hidden;
        }

        .cover-container {
            max-width: 60vw;
        }

        .nav-link {
            padding: 0.25rem 0;
            font-weight: 700;
            color: rgba(255, 255, 255, 0.6);
            margin-left: 1.5rem;
            border-bottom: 0.25rem solid transparent;
            text-decoration: none;
        }

        .nav-link:hover,
        .nav-link:focus {
            color: rgba(255, 255, 255, 0.9);
            border-bottom-color: rgba(255, 255, 255, 0.4);
        }

        .nav-link.active {
            color: white;
            border-bottom-color: white;
        }

        .btn-secondary,
        .btn-secondary:hover,
        .btn-secondary:focus {
            color: #333;
            text-shadow: none;
            transition: all 0.3s ease;
        }
        
        .btn-secondary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }

        .masthead-brand {
            margin-bottom: 0;
            font-weight: bold;
            font-size: 1.5rem;
            letter-spacing: 1px;
        }
    </style>
</head>

<body class="d-flex text-center text-white">
    <div class="cover-container d-flex w-100 h-100 p-3 mx-auto flex-column">
        <header class="mb-auto mt-3">
            <div>
                <h3 class="float-md-start masthead-brand">YelpCamp</h3>
                <nav class="nav nav-masthead justify-content-center float-md-end">
                    <a class="nav-link active" aria-current="page" href="/">Home</a>
                    <a class="nav-link" href="/campgrounds">Campgrounds</a>
                    <% if(!currentUser) { %>
                    <a class="nav-link" href="/login">Login</a>
                    <a class="nav-link" href="/register">Register</a>
                    <% } else { %>
                    <a class="nav-link" href="/logout">Logout</a>
                    <% } %>
                </nav>
            </div>
        </header>

        <main class="px-3" style="margin-top: -10vh;">
            <h1 class="display-3 fw-bold mb-4">YelpCamp</h1>
            <p class="lead fs-4 mb-4">Welcome to YelpCamp! <br> Jump right in and explore our gorgeous, hand-picked campgrounds from all over the world. <br>
                Feel free to share some of your own and comment on others!</p>
            <a href="/campgrounds" class="btn btn-lg btn-light fw-bold border-white bg-white mt-3 px-5 py-3">View
                Campgrounds</a>
        </main>

        <footer class="mt-auto text-white-50 pb-3">
            <p>&copy; 2026 YelpCamp | Built with ❤️</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>